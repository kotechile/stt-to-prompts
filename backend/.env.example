# Google Cloud Speech-to-Text Configuration
# Copy this file to .env and fill in your values

# Server Configuration
PORT=3000
NODE_ENV=development

# CORS Configuration (comma-separated list for production)
# ALLOWED_ORIGINS=chrome-extension://your-extension-id,http://localhost:3000

# Google Cloud Configuration
# Path to your service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json

# Optional: Google Cloud Project ID (if not in credentials file)
# GOOGLE_CLOUD_PROJECT=your-project-id

# Optional: API Key for additional authentication layer
# API_KEY=your-secret-api-key